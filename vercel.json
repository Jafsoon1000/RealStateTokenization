{
  "version": 2,
  "public": false,
  "builds": [
    {
      "src": "client/package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist" }
    }
  ],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "server/server.js" },
    { "source": "/(.*)", "destination": "client/$1" }
  ]
}
